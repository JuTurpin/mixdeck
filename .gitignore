# macOS
.DS_Store

# Node
node_modules/

# CMake build output (native/engine/build/ etc.) — not docs/build/, which holds
# the (versioned) docx-generation script, not build artifacts.
native/**/build/
native/**/build-electron/

# electron-vite build output
apps/**/out/

# TypeScript incremental build cache (tsc --build)
*.tsbuildinfo

# Xcode
xcuserdata/
*.xcodeproj/
*.xcworkspace/

# Editors
.vscode/
.idea/

# Fichiers audio de test personnels (gros binaires, pas du code source)
/test/
